<!DOCTYPE html>
<html>
<head>
    <title>Teacher Dashboard - ADUE Portal</title>
    <style>
        body{ font-family:Arial; max-width:800px; margin:30px auto; padding:20px; }
        input, select{ padding:6px; margin:5px; }
        button{ padding:8px; margin:5px; background:#4CAF50; color:white; border:none; cursor:pointer; }
        table{ width:100%; border-collapse: collapse; margin-top:20px; }
        th, td{ border:1px solid #ccc; padding:8px; text-align:left; }
    </style>
</head>
<body>

<h2>Teacher Dashboard</h2>
<button onclick="logout()">Logout</button>

<h3>Add Student</h3>
<input type="text" id="studentName" placeholder="Student Name">
<select id="studentClass">
<option>Year 7</option><option>Year 8</option><option>Year 9</option>
<option>Year 10</option><option>Year 11</option><option>Year 12</option>
</select>
<button onclick="addStudent()">Add Student</button>

<h3>My Students</h3>
<table id="studentsTable">
<tr><th>Name</th><th>Class</th></tr>
</table>

<script>
let users=JSON.parse(localStorage.getItem("users"))||[];
let loggedUser=JSON.parse(localStorage.getItem("loggedInUser"));
if(!loggedUser||loggedUser.role!=="teacher"){ alert("Access denied"); window.location.href="index.html"; }

function addStudent(){
    let name=document.getElementById("studentName").value.trim();
    let studentClass=document.getElementById("studentClass").value;
    if(!name){ alert("Fill student name"); return; }
    let student={name,role:"student",class:studentClass};
    users.push(student);
    localStorage.setItem("users",JSON.stringify(users));
    document.getElementById("studentName").value="";
    loadStudents();
}

function loadStudents(){
    let table=document.getElementById("studentsTable");
    table.innerHTML="<tr><th>Name</th><th>Class</th></tr>";
    users.forEach(u=>{ if(u.role==="student") table.innerHTML+=`<tr><td>${u.name}</td><td>${u.class||"-"}</td></tr>` });
}

function logout(){ localStorage.removeItem("loggedInUser"); window.location.href="index.html"; }

loadStudents();
</script>

</body>
</html>
