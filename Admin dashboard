<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard - ADUE Portal</title>
    <style>
        body{ font-family:Arial; max-width:800px; margin:30px auto; padding:20px; }
        input, select{ padding:6px; margin:5px; }
        button{ padding:8px; margin:5px; background:#4CAF50; color:white; border:none; cursor:pointer; }
        button:hover{ background:#45a049; }
        table{ width:100%; border-collapse: collapse; margin-top:20px; }
        th, td{ border:1px solid #ccc; padding:8px; text-align:left; }
    </style>
</head>
<body>

<h2>Admin Dashboard</h2>
<button onclick="logout()">Logout</button>

<h3>Add New Admin</h3>
<input type="text" id="adminName" placeholder="Full Name">
<input type="email" id="adminEmail" placeholder="Email">
<input type="password" id="adminPassword" placeholder="Password">
<button onclick="addAdmin()">Add Admin</button>

<h3>All Teachers</h3>
<table id="teachersTable">
<tr><th>Name</th><th>Email</th></tr>
</table>

<h3>All Students</h3>
<table id="studentsTable">
<tr><th>Name</th><th>Class</th><th>Email</th></tr>
</table>

<script>
let users=JSON.parse(localStorage.getItem("users"))||[];
let loggedUser=JSON.parse(localStorage.getItem("loggedInUser"));
if(!loggedUser||loggedUser.role!=="admin"){ alert("Access denied"); window.location.href="index.html"; }

function addAdmin(){
    let name=document.getElementById("adminName").value.trim();
    let email=document.getElementById("adminEmail").value.trim();
    let password=document.getElementById("adminPassword").value.trim();
    if(!name||!email||!password){ alert("Fill all fields"); return; }
    if(users.find(u=>u.email===email)){ alert("Email already exists"); return; }
    users.push({name,email,password,role:"admin"});
    localStorage.setItem("users",JSON.stringify(users));
    alert("Admin added successfully");
    document.getElementById("adminName").value="";
    document.getElementById("adminEmail").value="";
    document.getElementById("adminPassword").value="";
    loadTables();
}

function loadTables(){
    let teachers=document.querySelector("#teachersTable");
    let students=document.querySelector("#studentsTable");
    teachers.innerHTML="<tr><th>Name</th><th>Email</th></tr>";
    students.innerHTML="<tr><th>Name</th><th>Class</th><th>Email</th></tr>";
    users.forEach(u=>{
        if(u.role==="teacher") teachers.innerHTML+=`<tr><td>${u.name}</td><td>${u.email}</td></tr>`;
        if(u.role==="student") students.innerHTML+=`<tr><td>${u.name}</td><td>${u.class||"-"}</td><td>${u.email||"-"}</td></tr>`;
    });
}
function logout(){ localStorage.removeItem("loggedInUser"); window.location.href="index.html"; }
loadTables();
</script>

</body>
</html>
